VITE_OSIMART_BASE_URL=https://api.osimart.com/store/apis
VITE_OSIMART_AUTH_URL=https://api.osimart.com/auth
# Optional staff-only API root. Leave blank until Django exposes verified admin endpoints.
VITE_OSIMART_ADMIN_URL=
VITE_OSIMART_STORE_ID=
# Public OAuth client identifier. Never place a Google client secret in Vite env.
VITE_GOOGLE_CLIENT_ID=
VITE_SITE_URL=https://shop.yourdomain.com
VITE_SITE_NAME=TechHub
VITE_DEFAULT_OG_IMAGE=/og-image.svg
